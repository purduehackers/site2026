---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
}

const { title = 'Purdue Hackers' } = Astro.props;
---

<html lang="en">
  <head>
    <script
      defer
      src="https://umami.purduehackers.com/script.js"
      data-website-id="6b1a85c2-a54b-44ef-82c5-3c8ae34d8ec5"></script>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/glider.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <Font cssVariable="--font-whyte" preload />
    <Font cssVariable="--font-inconsolata" preload />
    <Font cssVariable="--font-silkscreen" preload />
    <Font cssVariable="--font-pixel-hackers" preload />
    <Font cssVariable="--font-polysans" preload />

    <Analytics />

    <title>{title}</title>
    <style is:global>
      .header-over-dark .nav-link {
        color: var(--color-bg) !important;
      }
      .header-over-dark .nav-link:hover {
        background: var(--color-bg) !important;
        color: #7d3bff !important;
      }
      .header-over-dark .mobile-menu-btn__line {
        background-color: var(--color-bg);
      }
    </style>
  </head>
  <body>
    <div id="loading-screen" style="position:fixed;inset:0;z-index:9999;background:#000;">
      <canvas id="loading-canvas" style="position:absolute;inset:0;width:100%;height:100%;image-rendering:pixelated;image-rendering:crisp-edges;"></canvas>
      <span id="loading-text" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1;font-family:var(--font-pixel-hackers),fantasy;font-size:1.5rem;color:var(--color-bg,#fffbf1);white-space:nowrap;">loading...</span>
    </div>
    <script is:inline>
    (function() {
      var BLOCK = 2;
      var DURATION = 2000;
      var DITHER_BAND = 0.5;
      var BAYER8 = [
        [ 0, 32,  8, 40,  2, 34, 10, 42],
        [48, 16, 56, 24, 50, 18, 58, 26],
        [12, 44,  4, 36, 14, 46,  6, 38],
        [60, 28, 52, 20, 62, 30, 54, 22],
        [ 3, 35, 11, 43,  1, 33,  9, 41],
        [51, 19, 59, 27, 49, 17, 57, 25],
        [15, 47,  7, 39, 13, 45,  5, 37],
        [63, 31, 55, 23, 61, 29, 53, 21]
      ];

      function bezier(x1, y1, x2, y2) {
        return function(t) {
          var lo = 0, hi = 1, mid;
          for (var i = 0; i < 20; i++) {
            mid = (lo + hi) / 2;
            var u = 1 - mid;
            var x = 3 * x1 * u * u * mid + 3 * x2 * u * mid * mid + mid * mid * mid;
            if (x < t) lo = mid; else hi = mid;
          }
          var u = 1 - mid;
          return 3 * y1 * u * u * mid + 3 * y2 * u * mid * mid + mid * mid * mid;
        };
      }
      var ease = bezier(0.63, 0.06, 0.13, 0.87);

      var overlay = document.getElementById('loading-screen');
      var canvas = document.getElementById('loading-canvas');
      var loadText = document.getElementById('loading-text');
      if (!overlay || !canvas || !loadText) return;

      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var vw = window.innerWidth;
      var vh = window.innerHeight;

      canvas.width = vw * dpr;
      canvas.height = vh * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, vw, vh);

      document.documentElement.style.overflow = 'hidden';

      function startDither() {
        document.documentElement.style.overflow = '';
        overlay.style.background = 'transparent';
        overlay.style.pointerEvents = 'none';

        var cols = Math.ceil(vw / BLOCK);
        var rows = Math.ceil(vh / BLOCK);
        var blocks = [];

        for (var r = 0; r < rows; r++) {
          for (var c = 0; c < cols; c++) {
            var ny = rows > 1 ? r / (rows - 1) : 0;
            var bv = BAYER8[r % 8][c % 8] / 64;
            blocks.push([ny * (1 - DITHER_BAND) + bv * DITHER_BAND, c * BLOCK, r * BLOCK]);
          }
        }

        blocks.sort(function(a, b) { return a[0] - b[0]; });

        var textRect = loadText.getBoundingClientRect();
        var sweepScale = 1 / (1 - DITHER_BAND);
        var startTime = null;
        var idx = 0;

        function frame(ts) {
          if (startTime === null) startTime = ts;
          var progress = ease(Math.min((ts - startTime) / DURATION, 1));

          while (idx < blocks.length && blocks[idx][0] <= progress) {
            ctx.clearRect(blocks[idx][1], blocks[idx][2], BLOCK, BLOCK);
            idx++;
          }

          var sweepY = Math.min(progress * vh * sweepScale, vh);
          var clipPx = Math.max(0, sweepY - textRect.top);
          var clipPct = Math.min(100, (clipPx / textRect.height) * 100);
          loadText.style.clipPath = 'inset(' + clipPct + '% 0 0 0)';

          if ((ts - startTime) < DURATION) {
            requestAnimationFrame(frame);
          } else {
            overlay.remove();
          }
        }

        requestAnimationFrame(frame);
      }

      if (document.readyState === 'complete') {
        startDither();
      } else {
        window.addEventListener('load', startDither);
      }
    })();
    </script>
    <header
      id="site-header"
      class="fixed top-0 left-0 right-0 z-30 px-6 py-5 md:px-8 md:py-6 font-inconsolata"
    >
      <div class="flex items-center justify-between">
        <!-- toggle cursor trail / pixel cursor -->
        <button
          type="button"
          id="pixel-trail-toggle"
          class="pixel-trail-toggle is-active hidden md:inline-flex text-base uppercase tracking-wide font-semibold px-2 py-1"
          aria-pressed="true"
          aria-label="Cycle cursor effect"
        >
          GOOEY
        </button>

        <!-- desktopn nav -->
        <nav class="hidden md:flex gap-8 header-links">
          <a
            href="https://puhack.horse/discord"
            target="_blank"
            class="nav-link text-base text-black tracking-wide font-semibold"
            >DISCORD</a
          >
          <a
            href="https://events.purduehackers.com/"
            target="_blank"
            class="nav-link text-base text-black tracking-wide font-semibold"
            >EVENTS</a
          >
          <a
            href="https://blog.purduehackers.com/"
            target="_blank"
            class="nav-link text-base text-black tracking-wide font-semibold"
            >BLOG</a
          >
          <a
            href="https://grants.purduehackers.com/"
            target="_blank"
            class="nav-link text-base text-black tracking-wide font-semibold"
            >MICROGRANTS</a
          >
        </nav>

        <!-- mobile hanburger -->
        <button
          type="button"
          id="menu-toggle"
          class="mobile-menu-btn md:hidden ml-auto flex flex-col justify-center items-center w-10 h-10 gap-1.5 text-black focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-black"
          aria-expanded="false"
          aria-label="Open menu"
          aria-controls="mobile-menu"
        >
          <span class="mobile-menu-btn__line" aria-hidden="true"></span>
          <span class="mobile-menu-btn__line" aria-hidden="true"></span>
          <span class="mobile-menu-btn__line" aria-hidden="true"></span>
        </button>
      </div>
    </header>
    <!-- mobile menu overlay -->
    <div
      id="mobile-menu"
      class="mobile-menu fixed inset-0 z-20 bg-black font-inconsolata"
      aria-hidden="true"
      role="dialog"
      aria-label="Main menu"
    >
      <nav
        class="mobile-menu__nav flex flex-col justify-center min-h-full px-8 py-24 gap-6"
      >
        <a
          href="https://puhack.horse/discord"
          target="_blank"
          class="mobile-menu__link">DISCORD</a
        >
        <a
          href="https://events.purduehackers.com/"
          target="_blank"
          class="mobile-menu__link">EVENTS</a
        >
        <a
          href="https://blog.purduehackers.com/"
          target="_blank"
          class="mobile-menu__link">BLOG</a
        >
        <a
          href="https://grants.purduehackers.com/"
          target="_blank"
          class="mobile-menu__link">MICROGRANTS</a
        >
      </nav>
    </div>
    <slot />
    <script src="../scripts/header.ts"></script>
    <!-- <script src="../scripts/hoverSound.ts"></script> -->
  </body>
</html>
