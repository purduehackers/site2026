  <script>
    import { initPixelBlast } from '../scripts/PixelBlast';
    const MADE_WITH_OPTIONS = [
      'astro',
      'bees',
      'spills',
      'bursts ✷',
      'the abyss...',
      'friendship and love',
      'the power of awestruck',
      'horse feed electrolytes',
      'vercel',
      'eggz',
      'kiwis',
      'one william dollars',
      'acrylic from canal plastics',
      'blackberry jam',
      'pear and prosciutto croissants',
    ];
    function initMadeWith() {
      const span = document.getElementById('made-with-rotate');
      const container = document.getElementById('footer-made-with');
      if (!span || !container) return;
      let index = 2; // start at "spills"
      let intervalId: ReturnType<typeof setInterval> | null = null;
      const slowMs = 2500;
      const fastMs = 500;
      const fadeDuration = 200;
      let fading = false;
      function update() {
        const el = document.getElementById('made-with-rotate');
        if (!el || fading) return;
        fading = true;
        el.style.opacity = '0';
        setTimeout(() => {
          index = (index + 1) % MADE_WITH_OPTIONS.length;
          el.textContent = MADE_WITH_OPTIONS[index];
          el.style.opacity = '1';
          fading = false;
        }, fadeDuration);
      }
      function startInterval(ms: number) {
        if (intervalId) clearInterval(intervalId);
        intervalId = setInterval(update, ms);
      }
      startInterval(slowMs);
      container.addEventListener('mouseenter', () => startInterval(fastMs));
      container.addEventListener('mouseleave', () => startInterval(slowMs));
    }
    function init() {
      const root = document.getElementById('pixel-blast-root');
      if (root) {
        const cleanup = initPixelBlast(root, {
          variant: 'square',
          pixelSize: 2,
          color: '#000000',
          patternScale: 4.5,
          patternDensity: 1.5,
          pixelSizeJitter: 0,
          enableRipples: true,
          rippleSpeed: 0.3,
          rippleThickness: 0.15,
          rippleIntensityScale: 2,
          liquid: false,
          liquidStrength: 0.12,
          liquidRadius: 1.2,
          liquidWobbleSpeed: 5,
          speed: 0.5,
          edgeFade: 0,
          topFade: 0.25,
          transparent: true,
        });
        document.addEventListener('astro:before-swap', cleanup, { once: true });
      }
      initMadeWith();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
  <script>
    function initPhotoCaption() {
      const tip = document.getElementById('photo-caption') as HTMLElement | null;
      if (!tip) return;

      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      if (isMobile) return;

      const titleEl = tip.querySelector('.photo-caption__title') as HTMLElement;
      const descEl = tip.querySelector('.photo-caption__desc') as HTMLElement;
      const desktopCollage = document.querySelector('.photo-collage--desktop');
      if (!desktopCollage) return;
      const images = desktopCollage.querySelectorAll('[data-caption-title]');

      let active = false;

      function show(img: Element, e: MouseEvent) {
        const title = img.getAttribute('data-caption-title') || '';
        const desc = img.getAttribute('data-caption-desc') || '';
        titleEl.textContent = title;
        descEl.textContent = desc;
        active = true;
        positionTooltip(e);
        tip!.classList.add('is-visible');
      }

      function hide() {
        active = false;
        tip!.classList.remove('is-visible');
      }

      function positionTooltip(e: MouseEvent) {
        const offset = 16;
        let x = e.clientX + offset;
        let y = e.clientY + offset;
        const rect = tip!.getBoundingClientRect();
        if (x + rect.width > window.innerWidth - 8) {
          x = e.clientX - rect.width - offset;
        }
        if (y + rect.height > window.innerHeight - 8) {
          y = e.clientY - rect.height - offset;
        }
        tip!.style.left = x + 'px';
        tip!.style.top = y + 'px';
      }

      images.forEach((img) => {
        img.addEventListener('mouseenter', (e) => show(img, e as MouseEvent));
        img.addEventListener('mousemove', (e) => {
          if (active) positionTooltip(e as MouseEvent);
        });
        img.addEventListener('mouseleave', hide);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPhotoCaption);
    } else {
      initPhotoCaption();
    }
  </script>
  <script>
    import { initPhotoCollageParallax } from '../scripts/photoCollageParallax';

    const stopParallax = initPhotoCollageParallax();
    document.addEventListener(
      'astro:before-swap',
      () => {
        stopParallax();
      },
      { once: true }
    );
  </script>
