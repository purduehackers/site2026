---
import BaseLayout from '../layouts/BaseLayout.astro';
import PT from '../components/PT';
import Glider from '../components/GliderShader.astro';
import { getHeroDitherSvg, getPixelIndices } from '../utils/dither';
import LogoGrid from '../components/LogoSoup';
import PhotoCollageItems from '../components/PhotoCollageItems.astro';
import { getLatestShip } from '../lib/ships';

const latestShip = await getLatestShip();
const shipUser = latestShip?.username ?? 'Ray';
const shipTime = latestShip?.timeAgo ?? '3d ago';
const shipBody = latestShip?.content ?? 'Shipped privacy options for Purdue Hackers — opt out of data collection like in Commit Overflow.';
import Sprite from '../components/Sprite.astro';

const logoUrls = [
  '/logos/cloudflare-color.svg',
  '/logos/openai-color.svg',
  '/logos/tbc-color.svg',
  '/logos/kp-color.svg',
  '/logos/million-color.svg',
  '/logos/neuralink-color.svg',
  '/logos/sentry-color.svg',
  '/logos/spacex-color.svg',
  '/logos/vercel-color.svg',
];

const ditherSvg = getHeroDitherSvg(4, 64);
const buildPixels = getPixelIndices(50);
const backPixels = getPixelIndices(40);
const joinPixels = getPixelIndices(40);
const shouldEnablePixelCursor = true;
---

<BaseLayout>
  {
    shouldEnablePixelCursor && (
      <div
        id="pixel-trail-container"
        style="position: fixed; inset: 0; z-index: 10; pointer-events: none;"
      >
        <PT
          client:load
          gridSize={85}
          trailSize={0.05}
          maxAge={220}
          interpolate={3}
          gooeyFilter={{ id: 'custom-goo-filter', strength: 0 }}
        />
      </div>
    )
  }
  <div
    id="pixel-cursor-container"
    style="position: fixed; inset: 0; z-index: 10; pointer-events: none; display: none;"
  >
  </div>
  <main>
    <!-- glider is position:absolute and can extend below this section; overflow-hidden clipped those pixels so the dither strip looked stacked on top -->
    <section
      class="relative z-[2] isolate flex items-start md:items-start gap-16 px-4 pt-64 pb-8 sm:px-10 md:px-40 md:pt-32 md:pb-12 overflow-visible"
      style="background-color: var(--color-bg);"
    >
      <div class="flex flex-col gap-6">
        <img
          src="/title.svg"
          alt="Purdue Hackers"
          class="w-full max-w-2xl h-auto object-contain object-left shrink-0 noselect pb-6"
        />
        <p
          class="max-w-[36rem] font-inconsolata uppercase sm:text-lg md:text-xl font-semibold leading-relaxed mb-6"
        >
          A collective of
          <span class="text-[var(--color-accent-2)]">hobbyists</span>,
          <span class="text-[var(--color-primary)]">engineers</span>, and
          <span class="text-[var(--color-accent)]">artists</span>
          who make creative-technical software, hardware, and mixed media projects
        </p>
        <a
          href="https://events.purduehackers.com/"
          target="_blank"
          class="join-session-btn"
          style="--pixel-cols: 10; --pixel-color: var(--color-primary);"
        >
          <span class="join-session-btn__pixels" aria-hidden="true">
            {
              buildPixels.map((delayIndex) => (
                <span
                  class="join-session-btn__pixel"
                  style={`--i: ${delayIndex}`}
                />
              ))
            }
          </span>
          <span
            class="join-session-btn__label pointer-events-none text-[var(--color-bg)]"
            >build with us</span
          >
        </a>
      </div>
      <Glider
        gridCols={80}
        gridRows={100}
        cellSize={10}
        speedMs={100}
        class="glider z-10 shrink-0 absolute top-[35%] -translate-y-1/4 -left-10 md:top-1/4 md:translate-y-0 md:-right-20 md:left-auto"
      />
    </section>

    <section
      class="dither-strip relative z-0 h-[128px] w-full shrink-0"
      style={`background-image: url('${ditherSvg}'); background-size: 8px 128px; background-repeat: repeat-x; image-rendering: pixelated; image-rendering: crisp-edges;`}
      aria-hidden="true"
    >
    </section>
    <!-- photo collage: desktop only — between dither and dark section -->
    <div
      data-header-dark
      class="photo-collage photo-collage--desktop relative z-[3] hidden overflow-visible bg-black md:block"
    >
      <PhotoCollageItems ship={latestShip} />
    </div>
    <div class="photo-caption" id="photo-caption">
      <p class="photo-caption__title"></p>
      <p class="photo-caption__desc"></p>
    </div>

    <section
      class="photo-collage-after relative z-[2] min-h-screen flex flex-col items-center px-8 pb-16 bg-black text-[var(--color-bg)] text-center overflow-hidden"
    >
      <!-- creatura! -->
      <div class="absolute top-8 md:top-12 lg:top-20 -right-16 md:right-8 lg:right-24 scale-90 sm:scale-[1] md:scale-[1.35] lg:scale-[1.65]">
        <Sprite
          id="angry-guy-sprite"
          className=""
          backgroundImage="/sprites/angry_dude_sprite_pink.png"
          spriteSize={224}
          numRows={1}
          numCols={2}
          numFrames={2}
          duration={1.5}
        />
      </div>
      <div class="absolute -left-8 md:left-24 lg:left-32 top-1/3 md:top-1/2 lg:top-1/2 -translate-y-1/2 scale-[2] sm:scale-[2] md:scale-[2.8] lg:scale-[3.5] 2xl:scale-300 rotate-[-10deg]">
        <Sprite
          id="fish-with-legs-sprite"
          className=""
          backgroundImage="/sprites/fish_with_legs_sprite_indigo.png"
          spriteSize={124}
          numRows={1}
          numCols={2}
          numFrames={2}
          duration={1.5}
        />
      </div>
      <img
        src="/lizard_gun.png"
        alt=""
        class="absolute image-rendering-pixelated bottom-1/3 md:bottom-12 lg:bottom-12 -right-12 md:right-8 lg:right-12 w-40 h-auto md:w-56 lg:w-72 object-contain pointer-events-none"
        aria-hidden="true"
      />

      <!-- 1 -->
      <div class="mb-72 relative">
        <img
          src="/ph.svg"
          alt="Purdue Hackers"
          class="w-8 h-8 mb-6 mx-auto fill-[var(--color-secondary)]"
        />
        <p
          class="max-w-[36rem] font-inconsolata text-l md:text-xl uppercase font-semibold leading-relaxed mt-6"
        >
          Making something you're proud of is incredibly rewarding. But it's
          really hard to do alone. Since 2013, Purdue Hackers has been a home to
          build, ship, and demo creative-technical projects together. <br />
          <br /> Here's how we do it:
        </p>
      </div>

      <!-- 2 -->
      <div id="hack-night" class="mb-72 relative">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="w-8 h-8 mx-auto text-[var(--color-secondary)]"
          fill="currentColor"
        >
          <polygon
            points="22 17 22 19 21 19 21 20 20 20 20 21 18 21 18 22 16 22 16 23 10 23 10 22 8 22 8 21 6 21 6 20 5 20 5 19 4 19 4 17 3 17 3 15 2 15 2 9 3 9 3 7 4 7 4 5 5 5 5 4 6 4 6 3 8 3 8 2 10 2 10 1 15 1 15 2 13 2 13 3 11 3 11 4 10 4 10 6 9 6 9 8 8 8 8 12 9 12 9 14 10 14 10 16 11 16 11 17 13 17 13 18 15 18 15 19 19 19 19 18 21 18 21 17 22 17"
          ></polygon>
        </svg>
        <p
          class="max-w-[32rem] font-pixel-hackers text-4xl md:text-6xl leading-relaxed pb-6 pt-6"
        >
          Hack Night
        </p>
        <p class="max-w-[32rem] font-polysans text-l leading-relaxed">
          Hack Night happens <span class="highlight"
            >every Friday night at 8pm</span
          >, second floor of <a
            href="https://www.purdue.edu/bidc/"
            target="_blank"
            class="highlight hover:text-[var(--color-secondary)] underline transition-colors duration-300 motion-reduce:transition-none whitespace-nowrap"
            >the Bechtel Center</a
          >. It's a dedicated space to work on personal projects, join (or even
          run) workshops, and share your progress at Checkpoints or on <a
            href="https://discord.gg/ncJ3xmhV85"
            target="_blank"
            class="highlight hover:text-[var(--color-secondary)] underline transition-colors duration-300 motion-reduce:transition-none"
            >Discord</a
          >. Ends when the last person leaves (often until 6am or later).
        </p>
        <br />
        <p class="max-w-[36rem] font-polysans text-l leading-relaxed mb-4">
          A typical Hack Night schedule looks something like this:
        </p>
        <table class="font-inconsolata text-l md:text-xl mx-auto">
          <tbody>
            <tr>
              <td class="highlight pr-4 py-1 text-right">D~5~5|5 (8 pm):</td>
              <td class="py-1 uppercase text-left">Hacking begins</td>
            </tr>
            <tr>
              <td class="highlight pr-4 py-1 text-right">E~0~0|0 (9 pm):</td>
              <td class="py-1 uppercase text-left">Session 1</td>
            </tr>
            <tr>
              <td class="highlight pr-4 py-1 text-right">E~A~A|A (10 pm):</td>
              <td class="py-1 uppercase text-left">Session 2</td>
            </tr>
            <tr>
              <td class="highlight pr-4 py-1 text-right">0~0~0 (12 am):</td>
              <td class="py-1 uppercase text-left">Checkpoints</td>
            </tr>
          </tbody>
        </table>
        <p class="max-w-[32rem] pt-6 font-polysans text-l leading-relaxed">
          If you go to Purdue &mdash; whether you've never written code before
          or are highly technical, whether you're an art major or a CS major
          &mdash; <br />
          <span class="highlight">you're invited.</span>
        </p>
      </div>

      <!-- 3 -->
      <div id="projects" class="mb-72 relative">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          class="w-8 h-8 mx-auto text-[var(--color-secondary)]"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
        >
          <polygon
            points="3 17 4 17 4 18 3 18 3 20 1 20 1 17 2 17 2 16 3 16 3 17"
          ></polygon><polygon
            points="4 5 3 5 3 3 4 3 4 2 6 2 6 3 7 3 7 5 6 5 6 6 4 6 4 5"
          ></polygon><polygon
            points="23 17 23 20 21 20 21 18 20 18 20 17 21 17 21 16 22 16 22 17 23 17"
          ></polygon><polygon
            points="20 16 19 16 19 20 18 20 18 21 17 21 17 20 16 20 16 17 17 17 17 14 18 14 18 12 17 12 17 13 16 13 16 14 8 14 8 13 7 13 7 12 6 12 6 14 7 14 7 17 8 17 8 20 7 20 7 21 6 21 6 20 5 20 5 16 4 16 4 15 3 15 3 14 2 14 2 11 3 11 3 8 4 8 4 7 6 7 6 8 7 8 7 10 8 10 8 11 9 11 9 7 15 7 15 11 16 11 16 10 17 10 17 8 18 8 18 7 20 7 20 8 21 8 21 11 22 11 22 14 21 14 21 15 20 15 20 16"
          ></polygon><polygon
            points="18 5 17 5 17 3 18 3 18 2 20 2 20 3 21 3 21 5 20 5 20 6 18 6 18 5"
          ></polygon>
        </svg>
        <p
          class="max-w-[32rem] font-pixel-hackers text-4xl md:text-6xl leading-relaxed pb-6 pt-6"
        >
          Community
        </p>
        <p class="max-w-[32rem] font-polysans text-l leading-relaxed">
          The heart of Purdue Hackers is our <a
            href="https://discord.gg/ncJ3xmhV85"
            target="_blank"
            class="highlight hover:text-[var(--color-secondary)] underline transition-colors duration-300 motion-reduce:transition-none"
            >Discord</a
          > community with 3000+ people. Share what you've made in <span
            class="highlight font-inconsolata">#ship</span
          >, chat about rainbows in <span class="highlight font-inconsolata"
            >#lounge</span
          >, and get technical help in <span class="highlight font-inconsolata"
            >#code</span
          >. Find people who push you to be your best, and make awesome things
          together.
        </p>
        <br />
        <p class="max-w-[32rem] font-polysans text-l leading-relaxed pb-6">
          We have lots of cool artifacts too, including <a
            href="https://blog.purduehackers.com/posts/papers-please"
            target="_blank"
            class="highlight hover:text-[var(--color-secondary)] underline transition-colors duration-300 motion-reduce:transition-none md:whitespace-nowrap"
            >custom hacker passports</a
          >, weekly acrylic badges designed and cut by members, <a
            href="https://sig.horse/"
            target="_blank"
            class="highlight hover:text-[var(--color-secondary)] underline transition-colors duration-300 motion-reduce:transition-none md:whitespace-nowrap"
            >a journal of projects done over summer</a
          >, and more. Interested in what community projects need taking up on?
          Come check out our <a
            href="https://shelter.purduehackers.com/"
            target="_blank"
            class="highlight hover:text-[var(--color-secondary)] underline transition-colors duration-300 motion-reduce:transition-none md:whitespace-nowrap"
            >Shelter</a
          >.
        </p>
        <a
          href="https://discord.gg/ncJ3xmhV85"
          target="_blank"
          class="join-session-btn"
          style="background: var(--color-bg); --pixel-cols: 6; --pixel-color: var(--color-bg); --pixel-color-hover: var(--color-secondary); --label-color: black;"
        >
          <span class="join-session-btn__pixels" aria-hidden="true">
            {
              joinPixels.map((delayIndex) => (
                <span
                  class="join-session-btn__pixel"
                  style={`--i: ${delayIndex}`}
                />
              ))
            }
          </span>
          <span class="join-session-btn__label pointer-events-none"
            >join us</span
          >
        </a>
      </div>

      <!-- mobile-only: ships + blog cards after Community -->
      <div class="md:hidden w-full max-w-2xl flex flex-col gap-4 mb-72">
        <p class="photo-collage__section-label">Latest Ship</p>
        <a href="https://ships.purduehackers.com/" target="_blank" class="photo-collage__card photo-collage__card--ships">
          <div class="photo-collage__card-head">
            <span class="photo-collage__card-user">{shipUser}</span>
            <span class="photo-collage__card-time">{shipTime}</span>
          </div>
          <p class="photo-collage__card-body">{shipBody}</p>
        </a>
        <p class="photo-collage__section-label" style="margin-top: 0.5rem;">Latest Blog</p>
        <a href="https://blog.purduehackers.com/" target="_blank" class="photo-collage__card photo-collage__card--blog">
          <p class="photo-collage__card-date">February 9, 2026</p>
          <p class="photo-collage__card-title">SIGHHORSE</p>
          <p class="photo-collage__card-author">Kart(avya) Vashishtha</p>
        </a>
      </div>

      <!-- 4 -->
      <div class="mb-72 relative">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="w-8 h-8 mx-auto text-[var(--color-secondary)]"
          fill="currentColor"
        >
          <polygon
            points="23 18 23 20 21 20 21 21 20 21 20 23 18 23 18 21 17 21 17 20 15 20 15 18 17 18 17 17 18 17 18 15 20 15 20 17 21 17 21 18 23 18"
          ></polygon><polygon
            points="23 4 23 6 21 6 21 7 20 7 20 9 18 9 18 7 17 7 17 6 15 6 15 4 17 4 17 3 18 3 18 1 20 1 20 3 21 3 21 4 23 4"
          ></polygon><polygon
            points="17 11 17 13 15 13 15 14 13 14 13 15 12 15 12 16 11 16 11 18 10 18 10 20 8 20 8 18 7 18 7 16 6 16 6 15 5 15 5 14 3 14 3 13 1 13 1 11 3 11 3 10 5 10 5 9 6 9 6 8 7 8 7 6 8 6 8 4 10 4 10 6 11 6 11 8 12 8 12 9 13 9 13 10 15 10 15 11 17 11"
          ></polygon>
        </svg>
        <p
          class="max-w-[32rem] font-pixel-hackers text-4xl md:text-6xl leading-relaxed pb-6 pt-6"
        >
          The Show
        </p>
        <p class="max-w-[32rem] font-polysans text-l leading-relaxed">
          At the end-of-semester, we hold the Show, an exhibit where our
          community comes together to share projects made throughout the
          semester at Hack Night and beyond.
        </p>
        <br />
        <p class="font-inconsolata text-xl font-semibold uppercase">
          ???????: Fall 2026 Show
        </p>
        <a
          href="https://spill.purduehackers.com/"
          target="_blank"
          class="font-inconsolata text-xl font-semibold uppercase underline hover:text-[var(--color-secondary)] transition-colors duration-300 motion-reduce:transition-none"
          >spill ≋: Fall 2025 Show</a
        >
        <br />
        <a
          href="https://burst.purduehackers.com/"
          target="_blank"
          class="font-inconsolata text-xl font-semibold uppercase underline hover:text-[var(--color-secondary)] transition-colors duration-300 motion-reduce:transition-none"
          >BURST ✷: Fall 2024 Show</a
        >
      </div>
      <div class="mb-72 relative w-full max-w-2xl">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="w-8 h-8 mx-auto text-[var(--color-secondary)]"
          fill="currentColor"
        >
          <polygon
            points="23 6 23 11 22 11 22 12 21 12 21 13 20 13 20 14 19 14 19 15 18 15 18 16 17 16 17 17 16 17 16 18 15 18 15 19 14 19 14 20 13 20 13 21 11 21 11 20 10 20 10 19 9 19 9 18 8 18 8 17 7 17 7 16 6 16 6 15 5 15 5 14 4 14 4 13 3 13 3 12 2 12 2 11 1 11 1 6 2 6 2 5 3 5 3 4 4 4 4 3 10 3 10 4 11 4 11 5 13 5 13 4 14 4 14 3 20 3 20 4 21 4 21 5 22 5 22 6 23 6"
          ></polygon></svg
        >
        <p
          class="max-w-[32rem] mx-auto text-center font-pixel-hackers text-4xl md:text-6xl leading-relaxed pb-6 pt-6"
        >
          Friends
        </p>
        <p class="font-inconsolata text-l md:text-xl font-semibold uppercase">
          <a
            href="https://mitchellh.com/"
            target="_blank"
            class="font-inconsolata text-l md:text-xl font-semibold uppercase underline hover:text-[var(--color-secondary)] transition-colors duration-300 motion-reduce:transition-none"
            >mitchell hashimoto</a
          >
          *
          <a
            href="https://www.paulgraham.com/"
            target="_blank"
            class="font-inconsolata text-l md:text-xl font-semibold uppercase underline hover:text-[var(--color-secondary)] transition-colors duration-300 motion-reduce:transition-none"
            >paul graham</a
          >
          *
          <a
            href="https://x.com/aidenybai"
            target="_blank"
            class="font-inconsolata text-l md:text-xl font-semibold uppercase underline hover:text-[var(--color-secondary)] transition-colors duration-300 motion-reduce:transition-none"
            >aiden bai</a
          >
          *
          <a
            href="https://x.com/jnnnthnn"
            target="_blank"
            class="font-inconsolata text-l md:text-xl font-semibold uppercase underline hover:text-[var(--color-secondary)] transition-colors duration-300 motion-reduce:transition-none"
            >jonathan unikowski</a
          >
        </p>
        <br />
        <LogoGrid logos={logoUrls} showGrid={false} />
        <p
          class="max-w-[32rem] font-polysans text-l mx-auto text-center leading-relaxed pt-6 pb-6"
        >
          Want to help us keep making?
        </p>
        <a
          href="https://hcb.hackclub.com/donations/start/purdue-hackers"
          target="_blank"
          class="join-session-btn"
          style="background: var(--color-bg); --pixel-cols: 6; --pixel-color: var(--color-bg); --pixel-color-hover: var(--color-secondary); --label-color: black;"
        >
          <span class="join-session-btn__pixels" aria-hidden="true">
            {
              backPixels.map((delayIndex) => (
                <span
                  class="join-session-btn__pixel"
                  style={`--i: ${delayIndex}`}
                />
              ))
            }
          </span>
          <span class="join-session-btn__label pointer-events-none"
            >back us</span
          >
        </a>
      </div>

    </section>

    <!-- photo collage: mobile only — sticky photo stack (cards shown separately above) -->
    <div
      data-header-dark
      class="photo-collage photo-collage--mobile relative z-[2] w-full md:hidden"
    >
      <PhotoCollageItems ship={latestShip} />
    </div>

    <section
      class="relative min-h-screen w-full bg-cover bg-center bg-no-repeat flex flex-col justify-end"
      style="background-image: url('/pic.png'); image-rendering: pixelated;"
    >
      <div class="absolute inset-0 z-[1] w-full h-full" aria-hidden="true">
        <div
          id="pixel-blast-root"
          class="w-full h-full"
          aria-label="PixelBlast interactive dither overlay"
        >
        </div>
      </div>
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent pointer-events-none"
        aria-hidden="true"
      >
      </div>
      <div
        class="relative z-10 flex flex-col-reverse md:flex-row flex-wrap items-start md:items-end justify-between gap-8 px-8 py-8 md:px-12 md:py-12 pointer-events-none"
      >
        <div
          id="footer-made-with"
          class="font-inconsolata text-[var(--color-bg)] text-left pointer-events-auto"
        >
          <p
            class="text-sm font-semibold md:text-base uppercase tracking-wide opacity-90"
          >
            made with <span
              id="made-with-rotate"
              style="display:inline-block;transition:opacity 0.3s ease;"
              >spills</span
            >
            <br />
            <a
              href="https://hcb.hackclub.com/donations/start/purdue-hackers"
              target="_blank"
              class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
              >Donate [501(c)(3) nonprofit]</a
            >
          </p>
        </div>
        <div
          class="flex gap-12 md:gap-16 font-inconsolata text-[var(--color-bg)]"
        >
          <div class="text-right">
            <p
              class="text-sm md:text-base font-semibold uppercase tracking-wide opacity-90 text-[var(--color-bg)]"
            >
              more from us
            </p>
            <p class="mt-2 text-lg md:text-xl uppercase text-[var(--color-bg)]">
              <a
                href="https://sig.horse/"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >SIGHORSE</a
              >
              <br />
              <a
                href="https://passports.purduehackers.com/"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >Passports</a
              >
              <br />
              <a
                href="https://shelter.purduehackers.com/"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >Shelter</a
              >
              <br />
              <a
                href="https://commit.purduehackers.com/"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >Commit Overflow</a
              >
              <br />
              <a
                href="https://ring.purduehackers.com/"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >Webring</a
              >
            </p>
          </div>
          <div class="text-right">
            <p
              class="text-sm md:text-base font-semibold uppercase tracking-wide opacity-90 text-[var(--color-bg)]"
            >
              find us on
            </p>
            <p class="mt-2 text-lg md:text-xl uppercase text-[var(--color-bg)]">
              <a
                href="https://discord.gg/purduehackers"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >Discord</a
              >
              <br />
              <a
                href="https://github.com/purduehackers"
                target="_blank"
                class="footer-overlay-link underline hover:text-[var(--color-secondary)] transition-colors font-semibold"
                >GitHub</a
